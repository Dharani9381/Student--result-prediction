def predict_student(hours, attendance, prev_marks, assignments, sleep):

    inp = scaler.transform([
        [hours, attendance, prev_marks, assignments, sleep]
    ])

    prediction = model.predict(inp)[0]      # 0 = FAIL, 1 = PASS
    prob = model.predict_proba(inp)[0]      # [P_fail, P_pass]

    label = 'PASS' if prediction == 1 else 'FAIL'
    confidence = prob[prediction] * 100

    return label, confidence, prob
